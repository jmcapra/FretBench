---
import '../styles/global.css';
import {
  getLeaderboard,
  getHardestQuestions,
  getTuningDifficulty,
  hasResults,
  getGeneratedAt,
  type LeaderboardEntry,
  type HardestQuestion,
  type TuningDifficulty,
} from '../data/loadResults';
import resultsData from '../data/results.json';

const showResults = hasResults();
const leaderboard = getLeaderboard();
const hardest = getHardestQuestions().slice(0, 10);
const tuningDiff = getTuningDifficulty();
const generatedAt = getGeneratedAt();
const evalVersion = (resultsData as any).eval_version ?? null;
const datasetVersion = (resultsData as any).dataset_version ?? null;
const datasetStats = (resultsData as any).dataset_stats ?? { total_cases: 182, tuning_counts: {} };
const tuningCounts: [string, number][] = Object.entries(datasetStats.tuning_counts ?? {});

const tuningAbbrev: Record<string, string> = {
  'Standard': 'Std',
  'Drop D': 'DropD',
  'Half-Step Down': 'HSD',
  'Drop Db': 'DropDb',
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Results — FretBench</title>
  <meta name="description" content="Full benchmark results — leaderboard, tuning difficulty, and hardest questions." />
  <link rel="icon" href="/favicon.ico" />
  <meta name="generator" content={Astro.generator} />
</head>
<body>

<nav>
  <a href="/" class="wordmark">FretBench</a>
  <div class="nav-links">
    <a href="/results" class="nav-link nav-link--active">Results</a>
    <a href="/blog" class="nav-link">Blog</a>
    <a href="https://github.com/jmcapra/FretBench" class="nav-link" target="_blank" rel="noopener">
      GitHub
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</nav>

{showResults ? (
<main>
  <!-- Header -->
  <section class="results-header">
    <h1>Benchmark Results</h1>
    <div class="results-meta">
      {datasetVersion && <span class="meta-item">Dataset <code>{datasetVersion}</code></span>}
      {evalVersion && <span class="meta-item">Eval <code>v{evalVersion}</code></span>}
      {generatedAt && <span class="meta-item">Last updated {new Date(generatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>}
    </div>
  </section>

  <!-- Chart.js Bar Chart -->
  <section class="section chart-section">
    <div class="chart-container">
      <canvas id="scoreChart"></canvas>
    </div>
  </section>

  <!-- Full Leaderboard -->
  <section class="section">
    <h2 class="section-heading">Leaderboard</h2>
    <div class="table-wrap">
      <table class="results-table">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th class="col-model">Model</th>
            <th class="col-score">Score</th>
            <th class="col-bar"></th>
            <th class="col-tuning">Tuning Breakdown</th>
            <th class="col-cost">Cost</th>
            <th class="col-date">Last Tested</th>
          </tr>
        </thead>
        <tbody>
          {leaderboard.map((m) => {
            const pct = m.score_pct;
            const hue = pct >= 70 ? 36 : pct >= 40 ? 30 : 15;
            const sat = pct >= 70 ? '80%' : pct >= 40 ? '55%' : '40%';
            const light = pct >= 70 ? '50%' : pct >= 40 ? '40%' : '32%';
            const barColor = `hsl(${hue}, ${sat}, ${light})`;
            return (
              <tr class={m.rank <= 3 ? 'top-three' : ''}>
                <td class="col-rank"><span class="rank-num">{m.rank}</span></td>
                <td class="col-model">
                  <span class="model-name">{m.model_name}{m.open_weight && <span class="ow-badge">OW</span>}</span>
                  <span class="model-provider">{m.provider}</span>
                </td>
                <td class="col-score"><span class="score-val">{pct.toFixed(1)}%</span></td>
                <td class="col-bar">
                  <div class="inline-bar-track">
                    <div class="inline-bar-fill" style={`width: ${pct}%; background: ${barColor};`} />
                  </div>
                </td>
                <td class="col-tuning">
                  <div class="tuning-stats">
                    {Object.entries(tuningAbbrev).map(([full, abbr]) => (
                      <span class="tuning-stat">
                        <span class="tuning-label">{abbr}</span>
                        <span class="tuning-val">{m.tuning_scores[full] != null ? `${m.tuning_scores[full].toFixed(0)}%` : '—'}</span>
                      </span>
                    ))}
                  </div>
                </td>
                <td class="col-cost">{m.total_cost != null ? `$${m.total_cost.toFixed(3)}` : '—'}</td>
                <td class="col-date">{m.completed_at ? new Date(m.completed_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—'}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Tuning Difficulty -->
  {tuningDiff.length > 0 && (
  <section class="section">
    <h2 class="section-heading">Tuning Difficulty</h2>
    <div class="tuning-cards">
      {tuningDiff.map((t) => (
        <div class="tuning-card">
          <span class="tuning-card-name">{t.tuning}</span>
          <div class="tuning-card-bar-wrap">
            <div class="tuning-card-bar" style={`width: ${t.avg_score_pct}%;`} />
          </div>
          <div class="tuning-card-footer">
            <span class="tuning-card-score">{t.avg_score_pct.toFixed(1)}%</span>
            <span class="tuning-card-runs">{t.total_runs} run{t.total_runs !== 1 ? 's' : ''}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
  )}

  <!-- Hardest Questions -->
  {hardest.length > 0 && (
  <section class="section">
    <h2 class="section-heading">Hardest Questions</h2>
    <div class="table-wrap">
      <table class="results-table hardest-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Tuning</th>
            <th>Success Rate</th>
            <th>Attempts</th>
          </tr>
        </thead>
        <tbody>
          {hardest.map((q) => (
            <tr>
              <td><code>{q.test_case_id}</code></td>
              <td>{q.tuning}</td>
              <td><span class="score-val">{q.success_rate.toFixed(1)}%</span></td>
              <td>{q.total_attempts}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
  )}

  <!-- Dataset Info -->
  <section class="section">
    <h2 class="section-heading">Dataset</h2>
    <div class="dataset-info">
      <div class="dataset-stat">
        <span class="dataset-stat-num">{datasetStats.total_cases}</span>
        <span class="dataset-stat-label">test cases</span>
      </div>
      {tuningCounts.map(([tuning, count]) => (
        <div class="dataset-stat">
          <span class="dataset-stat-num">{count}</span>
          <span class="dataset-stat-label">{tuning}</span>
        </div>
      ))}
    </div>
  </section>
</main>
) : (
<main class="empty-main">
  <p class="empty-state">No benchmark results available yet.</p>
</main>
)}

<footer>
  <p class="footer-note">Open source &middot; MIT license</p>
</footer>

<script define:vars={{ leaderboard }}>
  window.__CHART_DATA__ = leaderboard;
</script>

<script>
  import { Chart, registerables } from 'chart.js';
  Chart.register(...registerables);

  const data = (window as any).__CHART_DATA__;
  if (data && data.length > 0) {
    const labels = data.map((m: any) => m.model_name);
    const scores = data.map((m: any) => m.score_pct);

    const barColors = scores.map((s: number) => {
      if (s >= 70) return 'hsl(36, 80%, 50%)';
      if (s >= 40) return 'hsl(30, 55%, 40%)';
      return 'hsl(15, 40%, 32%)';
    });

    const ctx = document.getElementById('scoreChart') as HTMLCanvasElement;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          data: scores,
          backgroundColor: barColors,
          borderColor: barColors.map((c: string) => c.replace('50%)', '60%)').replace('40%)', '50%)').replace('32%)', '42%)')),
          borderWidth: 1,
          borderRadius: 4,
          maxBarThickness: 56,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#181510',
            borderColor: '#332E25',
            borderWidth: 1,
            titleColor: '#EDE7DA',
            bodyColor: '#C4B89E',
            titleFont: { family: "'Courier Prime', monospace", size: 13, weight: 'bold' },
            bodyFont: { family: "'Courier Prime', monospace", size: 12 },
            padding: 12,
            cornerRadius: 4,
            callbacks: {
              label: (ctx: any) => `Score: ${ctx.parsed.y.toFixed(1)}%`,
              afterLabel: (ctx: any) => {
                const m = data[ctx.dataIndex];
                return `Provider: ${m.provider}`;
              }
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: '#C4B89E',
              font: { family: "'Courier Prime', monospace", size: 10 },
              maxRotation: 45,
              minRotation: 25,
            },
            grid: { display: false },
            border: { color: '#332E25' }
          },
          y: {
            min: 0,
            max: 100,
            ticks: {
              color: '#7A6E58',
              font: { family: "'Courier Prime', monospace", size: 11 },
              callback: (v: any) => v + '%',
              stepSize: 20,
            },
            grid: { color: 'rgba(51, 46, 37, 0.5)' },
            border: { display: false }
          }
        },
        animation: {
          duration: 800,
          easing: 'easeOutQuart'
        }
      }
    });
  }
</script>

<style>
  main {
    flex: 1;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2.5rem;
  }

  .empty-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .empty-state {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-muted);
    text-align: center;
    padding: 6rem 2rem;
  }

  /* ─── Header ─── */
  .results-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.7s ease both;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .results-meta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-item {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .meta-item code {
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* ─── Sections ─── */
  .section {
    margin-bottom: 3.5rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  /* ─── Chart.js container ─── */
  .chart-section {
    padding: 1rem 0 2rem;
  }

  .chart-container {
    position: relative;
    width: 100%;
    height: 340px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem 1.5rem 1rem;
  }

  /* ─── Tables ─── */
  .table-wrap {
    overflow-x: auto;
  }

  .results-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .results-table thead th {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .results-table tbody td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    color: var(--text-muted);
  }

  .results-table tbody tr:last-child td {
    border-bottom: none;
  }

  .results-table tbody tr.top-three {
    border-left: 2px solid var(--amber-dim);
  }

  .col-rank { width: 3rem; text-align: center; }

  .rank-num {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--amber);
  }

  .col-model { min-width: 160px; }

  .model-name {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .ow-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber-dim);
    padding: 0.1rem 0.35rem;
    margin-left: 0.5rem;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  .model-provider {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .col-score { white-space: nowrap; }

  .score-val {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--amber);
    letter-spacing: 0.02em;
  }

  /* ─── Inline bar in table ─── */
  .col-bar { min-width: 120px; width: 180px; padding-right: 1rem !important; }

  .inline-bar-track {
    width: 100%;
    height: 10px;
    background: rgba(90, 80, 64, 0.15);
    border-radius: 5px;
    overflow: hidden;
  }

  .inline-bar-fill {
    height: 100%;
    border-radius: 5px;
    transition: width 0.5s ease;
  }

  .col-tuning { min-width: 220px; }

  .tuning-stats {
    display: flex;
    gap: 0.75rem;
  }

  .tuning-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .tuning-label {
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .tuning-val {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .col-cost { white-space: nowrap; }
  .col-date { white-space: nowrap; }

  /* ─── Tuning cards ─── */
  .tuning-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .tuning-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 2px solid var(--amber-dim);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tuning-card-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.04em;
  }

  .tuning-card-bar-wrap {
    width: 100%;
    height: 8px;
    background: rgba(90, 80, 64, 0.18);
    border-radius: 4px;
    overflow: hidden;
  }

  .tuning-card-bar {
    height: 100%;
    background: var(--amber);
    border-radius: 4px;
  }

  .tuning-card-footer {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .tuning-card-score {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--amber);
  }

  .tuning-card-runs {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* ─── Hardest table ─── */
  .hardest-table .score-val {
    font-size: 1rem;
  }

  /* ─── Dataset info ─── */
  .dataset-info {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .dataset-stat {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .dataset-stat-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--text);
  }

  .dataset-stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  footer { justify-content: flex-end; }

  /* ─── Responsive ─── */
  @media (max-width: 820px) {
    main { padding: 2.5rem 1.5rem; }
    .tuning-cards { grid-template-columns: repeat(2, 1fr); }
    .col-tuning, .col-cost { display: none; }
    .results-table thead .col-tuning,
    .results-table thead .col-cost { display: none; }
    .chart-container { height: 260px; padding: 1rem; }
  }

  @media (max-width: 480px) {
    .tuning-cards { grid-template-columns: 1fr; }
    .chart-container { height: 220px; }
  }
</style>

</body>
</html>
